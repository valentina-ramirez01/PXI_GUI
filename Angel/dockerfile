FROM registry.access.redhat.com/ubi9/ubi:latest

LABEL maintainer="Ricardo Garcia, Valentina Ramirez"

SHELL ["/bin/bash", "-c"]

RUN dnf -y update && \
    dnf -y install python3 python3-pip zsh && \
    dnf clean all

RUN python3 --version && zsh --version

WORKDIR /app

COPY . /app

RUN pip3 install --no-cache-dir -r requirements.txt || true

SHELL [ "/bin/zsh", "-c" ]

CMD ["zsh"]